# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/college-dispensary

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d

# ─── AI API keys (optional) ─────────────────────────────────────────────────
GOOGLE_AI_API_KEY=your_google_ai_api_key
OPENAI_API_KEY=your_openai_api_key

# ─── Email (optional) ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# ─── QR code ─────────────────────────────────────────────────────────────────
QR_CODE_SECRET=your_qr_code_secret

# ─── ERP integration (optional) ─────────────────────────────────────────────
ERP_API_URL=your_erp_api_url
ERP_API_KEY=your_erp_api_key

# ─── Client URL ──────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── SMS / OTP delivery (any one provider) ──────────────────────────────────
# Priority is: Fast2SMS → Twilio → TextBelt → console fallback (dev only).
# Override with SMS_PROVIDER = fast2sms | twilio | textbelt | console
SMS_PROVIDER=

# Fast2SMS (Indian provider, free signup → ~₹50 credit ≈ 50 OTPs).
# Sign up at https://www.fast2sms.com and copy the API key here.
# FAST2SMS_ROUTE is usually 'otp' (free DLT-OTP route) or 'q' (Quick SMS).
FAST2SMS_API_KEY=
FAST2SMS_ROUTE=otp

# Twilio (global, ~$15 free trial credit). For trial accounts, the destination
# number must be verified once in the Twilio console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# TextBelt (no signup required) — public key 'textbelt' = 1 free SMS / IP / day.
# Replace with a paid key for higher volume. Used automatically in production
# when nothing else is configured.
TEXTBELT_KEY=textbelt
