# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ─── Supabase (migration target — Phase 0) ──────────────────────────────────
# Server-side service-role client (NEVER ship to frontend):
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Public values (mirrored to client as REACT_APP_*):
REACT_APP_SUPABASE_URL=https://<project-ref>.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key_here

# ─── Database (legacy — to be removed after Phase 8 cutover) ────────────────
MONGODB_URI=mongodb://localhost:27017/college-dispensary

# ─── Authentication (legacy — to be removed after Phase 2) ──────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d

# ─── AI API keys (optional) ─────────────────────────────────────────────────
GOOGLE_AI_API_KEY=your_google_ai_api_key
OPENAI_API_KEY=your_openai_api_key

# ─── Email (optional) ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# ─── QR code ─────────────────────────────────────────────────────────────────
QR_CODE_SECRET=your_qr_code_secret

# ─── ERP integration (optional) ─────────────────────────────────────────────
ERP_API_URL=your_erp_api_url
ERP_API_KEY=your_erp_api_key

# ─── Client URL ──────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
