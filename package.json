{
  "name": "dormdoc",
  "version": "1.0.0",
  "description": "DormDoc — College Dispensary Management System for BIT Mesra",
  "main": "src/server/server.js",
  "scripts": {
    "build": "cd src/client && npm run build",
    "start": "node src/server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon src/server/server.js",
    "client": "cd src/client && npm start",
    "install-client": "cd src/client && npm install",
    "heroku-postbuild": "npm run install-client && npm run build"
  },
  "keywords": [
    "college",
    "dispensary",
    "medical",
    "management",
    "system",
    "bit-mesra",
    "dormdoc"
  ],
  "author": "mightbeanshuu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mightbeanshuu/DormDoc.git"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.4",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}